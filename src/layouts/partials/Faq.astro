---
const { faq } = Astro.props;
---

<section class="section w-full flex justify-center">
  <div class="w-full max-w-[872px] px-6 flex flex-col gap-[64px] items-center">
    <div class="text-center flex flex-col gap-4">
      <h2 class="text-[48px] md:text-[61px] font-bold text-[#232323] tracking-[0.3691px] leading-[1.4]">
        {faq.title || "Frequently asked questions"}
      </h2>
      <p class="text-[18px] text-[#232323]/60 leading-[28px] tracking-[-0.4395px]">
        {faq.description || "Got questions? We've got answers."}
      </p>
    </div>

    <div class="flex flex-col gap-4 w-full">
      {faq.questions.map((item: any) => (
        <div class="bg-[#f5f4f1] border border-[#232323]/10 rounded-[16px] p-6 shadow-[0px_1px_20px_0px_rgba(0,0,0,0.1)] flex justify-between items-center group cursor-pointer hover:border-[#232323]/20 transition-all">
          <div class="flex flex-col gap-2">
            <p class="text-[20px] font-bold text-[#232323] leading-[28px] tracking-[-0.4492px]">
              {item.question}
            </p>
            <p class="hidden group-[.active]:block text-[16px] text-[#232323]/70 leading-[24px]">
              {item.answer}
            </p>
          </div>
          <div class="w-8 h-8 bg-[#232323]/5 border border-[#232323]/10 rounded-full flex items-center justify-center group-hover:bg-[#232323]/10 transition-colors">
            <svg class="w-5 h-5 text-[#232323]/40 group-hover:text-[#232323]/60 transition-colors" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
               <path d="M5 10h10M10 5l5 5-5 5"></path>
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Simple toggle logic
  const faqItems = document.querySelectorAll('.group.cursor-pointer');
  faqItems.forEach(item => {
    item.addEventListener('click', () => {
      item.classList.toggle('active');
    });
  });
</script>
