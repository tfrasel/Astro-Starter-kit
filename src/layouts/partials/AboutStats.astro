---
const { data } = Astro.props;
---

<!-- Stats: Numbers that speak -->
<section class="section-none px-6">
  <div class="mx-auto w-[calc(100%-64px)] bg-[#ebe9e2] rounded-[24px] py-[120px] xl:px-[80px] flex flex-col items-center">
    <div class="w-full max-w-[1384px] flex flex-col items-center gap-[64px]">
      
      <!-- Stats Header -->
      <div class="text-center flex flex-col items-center gap-[16px] max-w-[660px]">
        <h2 class="font-bold leading-[1.2] text-[#232323] text-[40px] md:text-[61px] tracking-[0.35px] font-primary m-0">
          {data.title}
        </h2>
        <p class="font-normal leading-[28px] text-[18px] md:text-[20px] text-[rgba(35,35,35,0.8)] m-0 font-primary tracking-[-0.45px]" set:html={data.description} />
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[24px] w-full">
        {data.figures.map((stat: any) => (
          <div class="bg-[#f5f4f1] border border-[rgba(35,35,35,0.1)] rounded-[24px] p-[32px] flex flex-col gap-[16px] items-center justify-center text-center">
            <span class="font-bold leading-none text-[#232323] text-[56px] md:text-[72px] font-primary">
              {stat.value}
            </span>
            <span class="font-medium leading-[20px] text-[14px] md:text-[16px] text-[rgba(35,35,35,0.7)] font-primary tracking-[0.7px] uppercase">
              {stat.label}
            </span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
