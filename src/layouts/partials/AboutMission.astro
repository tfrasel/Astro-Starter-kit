---
const { data } = Astro.props;
---

<!-- Mission Section: text left + image right -->
<section class="section overflow-hidden pb-30 pt-0">
  <div class="container px-6 xl:px-0 mx-auto w-full xl:max-w-[1320px]">
    <div class="flex flex-col lg:flex-row items-center gap-[96px]">
      
      <!-- Text Content (left side) -->
      <div class="w-full lg:w-[42%] flex flex-col gap-[48px] shrink-0">
        <div class="flex flex-col gap-[24px]">
          <!-- Overline -->
          <span class="font-bold text-[14px] text-[#232323] tracking-[2.8px] uppercase leading-[20px] font-primary">
            {data.title}
          </span>
          <!-- Heading -->
          <h2 class="font-bold leading-[1.2] text-[#232323] text-[40px] md:text-[61px] tracking-[0] font-primary m-0">
            {data.heading}
          </h2>
        </div>
        <!-- Body text -->
        <p class="font-normal leading-[1.625] text-[18px] md:text-[20px] text-[rgba(35,35,35,0.7)] m-0 font-primary">
          {data.description}
        </p>
      </div>

      <!-- Image (right side) -->
      <div class="w-full lg:w-[58%]">
        <div class="w-full h-[350px] md:h-[479px] rounded-[20px] overflow-hidden bg-[#e0dfdb] shadow-[0px_20px_40px_-15px_rgba(50,27,21,0.2)]">
          {data.image ? (
            <img src={data.image} alt={data.heading} class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
            <div class="w-full h-full flex flex-col items-center justify-center bg-[rgba(35,35,35,0.05)] hidden">
              <svg class="w-16 h-16 text-[rgba(35,35,35,0.2)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          ) : (
            <div class="w-full h-full flex flex-col items-center justify-center bg-[rgba(35,35,35,0.05)]">
              <svg class="w-16 h-16 text-[rgba(35,35,35,0.2)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          )}
        </div>
      </div>

    </div>
  </div>
</section>
