---
const { title, subtitle, description } = Astro.props;
---

<!-- Features Hero Section -->
<section class="section w-full flex justify-center">
  <!-- Beige rounded-bottom band -->
  <div class="mx-auto w-[calc(100%-64px)] bg-[#ebe9e2] rounded-b-[16px] pt-[228px] pb-[140px] relative top-0 flex flex-col items-center">
    <div class="w-full max-w-[1320px] text-center px-6 xl:px-0 relative z-20 flex flex-col items-center">
      
      <!-- Badge pill -->
      {subtitle && (
        <div class="inline-flex items-center gap-2 rounded-full border border-[rgba(35,35,35,0.2)] bg-[#f7f5f0] px-[16px] py-[8px] shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1),0px_1px_2px_0px_rgba(0,0,0,0.1)] mb-8">
          <span class="w-[8px] h-[8px] rounded-full bg-[#232323] border-[3px] border-[#e7e3de]"></span>
          <span class="text-[14px] font-semibold text-[#232323] tracking-[-0.1504px] leading-[20px]">{subtitle}</span>
        </div>
      )}

      <!-- Title -->
      <h1 class="font-bold leading-[1.2] text-[#232323] text-[48px] md:text-[80px] tracking-[-2.4px] m-0 max-w-[1005px] font-primary whitespace-pre-line">
        {title}
      </h1>

      <!-- Description -->
      <p class="font-medium leading-[32.5px] text-[rgba(35,35,35,0.7)] text-[18px] md:text-[20px] max-w-[862px] mt-[32px] m-0 font-primary">
        {description}
      </p>
    </div>
  </div>
</section>
