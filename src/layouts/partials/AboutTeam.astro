---
import { markdownify } from "@/lib/utils/textConverter";
import ImageMod from "@/components/ImageMod.astro";
const { data } = Astro.props;
---

<section class="section pb-[120px]">
  <div class="container px-6 xl:px-0 mx-auto w-full xl:max-w-[1320px]">
    
    <!-- Section Header -->
    <div class="flex flex-col items-center text-center gap-[16px] mb-[80px]">
      <h2 class="font-bold leading-[1.2] text-[#232323] text-[40px] md:text-[48px] tracking-[0.37px] font-primary m-0">
        {data.title}
      </h2>
      <p class="font-normal leading-[1.6] text-[18px] text-[rgba(35,35,35,0.7)] max-w-[600px] m-0 font-primary">
        {data.description}
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[32px]">
      {data.members.map((member: any) => (
        <div class="flex flex-col gap-[24px] group cursor-pointer">
          
          <!-- Image Container -->
          <div class="w-full aspect-[4/5] rounded-[24px] overflow-hidden bg-[#e0dfdb] shadow-[0px_10px_20px_-5px_rgba(50,27,21,0.1)] transition-transform duration-500 group-hover:-translate-y-2 relative">
            {member.image ? (
               <img src={member.image} alt={member.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
               <div class="w-full h-full flex flex-col items-center justify-center bg-[rgba(35,35,35,0.05)] hidden">
                 <svg class="w-12 h-12 text-[rgba(35,35,35,0.2)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                   <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                   <circle cx="12" cy="7" r="4"></circle>
                 </svg>
               </div>
            ) : (
               <div class="w-full h-full flex flex-col items-center justify-center bg-[rgba(35,35,35,0.05)]">
                 <svg class="w-12 h-12 text-[rgba(35,35,35,0.2)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                   <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                   <circle cx="12" cy="7" r="4"></circle>
                 </svg>
               </div>
            )}
            
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500 rounded-[24px]"></div>
          </div>

          <!-- Content -->
          <div class="flex flex-col gap-[8px] text-center">
            <h3 class="font-bold text-[20px] text-[#232323] leading-none m-0 font-primary tracking-[-0.3px]">
              {member.name}
            </h3>
            <span class="font-normal text-[16px] text-[rgba(35,35,35,0.6)] leading-none font-primary">
              {member.role}
            </span>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
