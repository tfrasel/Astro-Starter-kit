---
const { action } = Astro.props;
---

<section class="pb-[120px]">
  <div class="container mx-auto px-6 xl:px-0">
    <div class="flex flex-col lg:flex-row gap-[24px] items-stretch min-h-[639px]">
      
      <!-- Left: Contact Details -->
      <div class="bg-[#f5f4f1] border border-[transparent] rounded-[20px] px-[40px] py-[56px] w-full lg:w-[536px] shrink-0 flex flex-col justify-between shadow-[0px_10px_15px_0px_rgba(0,0,0,0.1),0px_4px_6px_0px_rgba(0,0,0,0.1)]">
        <div class="flex flex-col gap-[16px]">
          <h2 class="font-bold text-[48px] text-[#121212] leading-[1.4] m-0 font-primary tracking-tight">Get in Touch</h2>
          <div class="font-medium text-[18px] text-[#3d434c] leading-[1.4] m-0 font-primary">
            <p class="mb-0">Email, call, or complete the form learn how Kion</p>
            <p>management and governance challenges.</p>
          </div>
        </div>

        <div class="flex flex-col gap-[24px] mt-[60px]">
          <!-- Email -->
          <div class="flex flex-col gap-[8px]">
            <div class="flex gap-[8px] items-center text-[#121212]">
              <div class="w-6 h-6 flex items-center justify-center">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6"><path d="M22 6C22 4.9 21.1 4 20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6ZM20 6L12 11L4 6H20ZM20 18H4V8L12 13L20 8V18Z" fill="currentColor"/></svg>
              </div>
              <span class="font-medium text-[18px] leading-[1.4] font-primary">Email</span>
            </div>
            <p class="font-normal text-[16px] text-[#606977] leading-[1.5] m-0 font-primary">datasource@gmail.com</p>
          </div>

          <!-- Address -->
          <div class="flex flex-col gap-[8px]">
            <div class="flex gap-[8px] items-center text-[#121212]">
              <div class="w-6 h-6 flex items-center justify-center">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6"><path d="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2ZM12 11.5C10.62 11.5 9.5 10.38 9.5 9C9.5 7.62 10.62 6.5 12 6.5C13.38 6.5 14.5 7.62 14.5 9C14.5 10.38 13.38 11.5 12 11.5Z" fill="currentColor"/></svg>
              </div>
              <span class="font-medium text-[18px] leading-[1.4] font-primary">Address</span>
            </div>
            <p class="font-normal text-[16px] text-[#606977] leading-[1.5] m-0 max-w-[233px] font-primary">4517 Washington Ave. Manchester, Kentucky 39495</p>
          </div>

          <!-- Socials -->
          <div class="flex flex-col gap-[16px] mt-[24px]">
            <span class="font-medium text-[18px] text-[#121212] leading-[1.4] font-primary">Follow us</span>
            <div class="flex gap-[8px] items-center">
              {[
                { name: 'LinkedIn', icon: 'M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.46c0-1.08-.34-2.11-1.38-2.11-1.01 0-1.38.79-1.38 1.43v6.14h-2.16V9.03h2.16v1.07c.36-.57 1.05-1.07 2.1-.11 1.05.96 1.15 2.15 1.15 3.39v5.12h-2.09l-.4-.03zM7 19h2.16V9h-2.16v10M8.1 7.66h.05c.78 0 1.41-.63 1.41-1.41a1.41 1.41 0 0 0-2.82 0c0 .78.63 1.41 1.36 1.41z' },
                { name: 'Twitter', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
                { name: 'Website', icon: 'M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm-5-8a5 5 0 1 1 5 5 5 5 0 0 1-5-5z' }
              ].map((social) => (
                <a href="#" class="w-[48px] h-[48px] bg-white border border-[rgba(35,35,35,0.1)] rounded-full flex items-center justify-center shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1)] hover:bg-[rgba(35,35,35,0.05)] transition-colors" aria-label={social.name}>
                  <svg class="w-5 h-5 text-[#232323]" viewBox="0 0 24 24" fill="currentColor">
                    <path d={social.icon}/>
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-[#f5f4f1] border border-[transparent] rounded-[16px] p-[40px] w-full lg:w-[760px] shadow-[0px_10px_15px_0px_rgba(0,0,0,0.1),0px_4px_6px_0px_rgba(0,0,0,0.1)]">
        <form action={action} method="POST" class="flex flex-col gap-[32px]">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px]">
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4] font-primary">Name</label>
              <input type="text" name="name" placeholder="Type your name" required class="bg-[#ebe9e2] border-[#c9cdd3] border border-solid rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors font-primary" />
            </div>
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4] font-primary">Email</label>
              <input type="email" name="email" placeholder="joneemail@gmail.com" required class="bg-[#ebe9e2] border-[#f4f5f6] border border-solid rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors font-primary" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px]">
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4] font-primary">Phone</label>
              <input type="tel" name="phone" placeholder="Enter your Phone" class="bg-[#ebe9e2] border-[#f4f5f6] border border-solid rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors font-primary" />
            </div>
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4] font-primary">Subject</label>
              <input type="text" name="subject" placeholder="Write your subject" required class="bg-[#ebe9e2] border-[#f4f5f6] border border-solid rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors font-primary" />
            </div>
          </div>

          <div class="flex flex-col gap-[8px]">
            <label class="font-semibold text-[20px] text-[#232323] leading-[1.4] font-primary">Message</label>
            <textarea name="message" placeholder="Write your message here" required class="bg-[#ebe9e2] border-[#f4f5f6] border border-solid rounded-[10px] px-[20px] py-[16px] min-h-[143px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors resize-none w-full font-primary"></textarea>
          </div>

          <div class="flex flex-col gap-[24px]">
            <div class="flex items-start gap-[8px] text-[16px] text-[#232323] leading-[1.5] font-primary">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#232323] shrink-0"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>This site is protected by reCAPTCHA and the Google Privacy Policy and Terms of Service apply.</span>
            </div>

            <button type="submit" class="bg-[#232323] h-[60px] rounded-full flex items-center justify-center gap-[8px] text-[#ece5d8] w-full group hover:opacity-90 tracking-[-0.3125px] transition-opacity cursor-pointer border-none outline-none font-primary">
              <span class="font-medium text-[16px] leading-[24px]">Send message</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"><path d="M3.3335 8H12.6668" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.3335 4.6665L12.6668 7.99984L9.3335 11.3332" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          
        </form>
      </div>

    </div>
  </div>
</section>
