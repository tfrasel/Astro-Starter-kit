---
const { action } = Astro.props;
---

<section class="pb-[120px]">
  <div class="container xl:max-w-[1320px] mx-auto px-6 xl:px-0">
    <div class="flex flex-col lg:flex-row gap-[24px] items-stretch min-h-[639px]">
      
      <!-- Left: Contact Details -->
      <!-- Left: Contact Details -->
      <div class="bg-[#f5f4f1] border border-[transparent] rounded-[20px] px-[40px] py-[56px] w-full lg:w-[536px] shrink-0 flex flex-col justify-between shadow-[0px_10px_15px_0px_rgba(0,0,0,0.1),0px_4px_6px_0px_rgba(0,0,0,0.1)]">
        <div class="flex flex-col gap-[16px]">
          <h2 class="font-bold text-[48px] text-[#121212] leading-[1.4] m-0 font-primary tracking-tight">Get in Touch</h2>
          <p class="font-medium text-[18px] text-[#3d434c] leading-[1.4] m-0">
            Email, call, or complete the form to learn how we can help solve your management and governance challenges.
          </p>
        </div>

        <div class="flex flex-col gap-[24px] mt-[60px]">
          <!-- Email -->
          <div class="flex flex-col gap-[8px]">
            <div class="flex gap-[8px] items-center text-[#121212]">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              <span class="font-medium text-[18px] leading-[1.4]">Email</span>
            </div>
            <p class="font-normal text-[16px] text-[#606977] leading-[1.5] m-0">datasource@gmail.com</p>
          </div>

          <!-- Address -->
          <div class="flex flex-col gap-[8px]">
            <div class="flex gap-[8px] items-center text-[#121212]">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <span class="font-medium text-[18px] leading-[1.4]">Address</span>
            </div>
            <p class="font-normal text-[16px] text-[#606977] leading-[1.5] m-0 max-w-[233px]">4517 Washington Ave. Manchester, Kentucky 39495</p>
          </div>

          <!-- Socials -->
          <div class="flex flex-col gap-[8px] mt-[24px]">
            <span class="font-medium text-[18px] text-[#121212] leading-[1.4]">Follow us</span>
            <div class="flex gap-[8px] items-center">
              {[1, 2, 3].map((i) => (
                <a href="#" class="w-[48px] h-[48px] bg-white border border-[rgba(35,35,35,0.1)] rounded-full flex items-center justify-center shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1)] hover:bg-[rgba(35,35,35,0.05)] transition-colors">
                  <svg class="w-5 h-5 text-[#232323]" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-[#f5f4f1] border border-[transparent] rounded-[16px] p-[40px] w-full lg:w-[760px] shadow-[0px_10px_15px_0px_rgba(0,0,0,0.1),0px_4px_6px_0px_rgba(0,0,0,0.1)]">
        <form action={action} method="POST" class="flex flex-col gap-[32px]">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px]">
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4]">Name</label>
              <input type="text" name="name" placeholder="Type your name" required class="bg-[#ebe9e2] border-none rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors" />
            </div>
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4]">Email</label>
              <input type="email" name="email" placeholder="joneemail@gmail.com" required class="bg-[#ebe9e2] border-none rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-[16px]">
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4]">Phone</label>
              <input type="tel" name="phone" placeholder="Enter your Phone" class="bg-[#ebe9e2] border-none rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors" />
            </div>
            <div class="flex flex-col gap-[8px]">
              <label class="font-semibold text-[20px] text-[#232323] leading-[1.4]">Subject</label>
              <input type="text" name="subject" placeholder="Write your subject" required class="bg-[#ebe9e2] border-none rounded-[10px] px-[20px] h-[56px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors" />
            </div>
          </div>

          <div class="flex flex-col gap-[8px]">
            <label class="font-semibold text-[20px] text-[#232323] leading-[1.4]">Message</label>
            <textarea name="message" placeholder="Write your message here" required class="bg-[#ebe9e2] border-none rounded-[10px] px-[20px] py-[16px] min-h-[143px] text-[16px] text-[#232323] placeholder-[rgba(35,35,35,0.5)] focus:outline-none focus:ring-1 focus:ring-[#232323] transition-colors resize-none w-full"></textarea>
          </div>

          <div class="flex flex-col gap-[24px]">
            <div class="flex items-start gap-[8px] text-[16px] text-[#232323] leading-[1.5]">
              <svg class="w-6 h-6 text-[#232323] shrink-0 mt-[2px]" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.11 0 2-.9 2-2V5c0-1.1-.89-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
              <span>This site is protected by reCAPTCHA and the Google Privacy Policy and Terms of Service apply.</span>
            </div>

            <button type="submit" class="bg-[#232323] h-[60px] rounded-full flex items-center justify-center gap-[8px] text-[#ece5d8] w-full group hover:opacity-90 tracking-tight transition-opacity cursor-pointer border-none outline-none">
              <span class="font-medium text-[16px] leading-[24px]">Send message</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3.333 8h9.334M9.333 4.667l3.334 3.333-3.334 3.334" />
              </svg>
            </button>
          </div>
          
        </form>
      </div>

    </div>
  </div>
</section>
