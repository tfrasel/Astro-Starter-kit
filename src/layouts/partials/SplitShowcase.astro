---
import { markdownify } from "@/lib/utils/textConverter";

const { split_showcase } = Astro.props;
---

<section class="section-bg mx-auto w-[calc(100%-64px)] bg-[#ebe9e2] rounded-[24px] overflow-hidden relative">
  <div class="container relative z-10 w-full">
    <div class="flex flex-col gap-[140px] w-full">
      {
        split_showcase.map((section: any, index: number) => {
          const isLeft = section.image_align === "left";
          return (
            <div class={`flex flex-col lg:flex-row items-center gap-[68px] w-full ${isLeft ? "lg:flex-row-reverse" : ""}`}>
              
              <!-- Content Block -->
              <div class="w-full lg:w-[692px] shrink-0 flex flex-col gap-[48px] items-start text-left">
                <div class="flex flex-col gap-[32px] w-full">
                  <div class="flex flex-col gap-[16px] w-full">
                    <div class="flex flex-col gap-[16px] w-full">
                      <p class="text-[14px] uppercase tracking-[2.65px] text-[rgba(35,35,35,0.5)] font-bold">
                        {section.subtitle}
                      </p>
                      <h2 
                        class="text-[40px] lg:text-[61px] text-[#232323] font-bold leading-[1.4] tracking-[0.35px]"
                        set:html={markdownify(section.title)}
                      />
                    </div>
                    <p 
                      class="text-[18px] lg:text-[20px] text-[rgba(35,35,35,0.8)] font-normal leading-[28px] tracking-[-0.44px]"
                      set:html={markdownify(section.content)}
                    />
                  </div>
                  
                  {section.bulletpoints && section.bulletpoints.length > 0 && (
                    <div class="flex flex-col gap-[16px]">
                      {section.bulletpoints.map((bullet: string) => (
                        <div class="flex items-start lg:items-center gap-[16px]">
                          <div class="h-[24px] w-[24px] shrink-0 rounded-full border border-[rgba(35,35,35,0.6)] flex items-center justify-center mt-1 lg:mt-0">
                            <svg class="h-[12px] w-[12px] text-[#232323]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
                            </svg>
                          </div>
                          <p class="text-[16px] text-[rgba(35,35,35,0.8)] font-normal leading-[28px] tracking-[-0.44px]" set:html={markdownify(bullet)} />
                        </div>
                      ))}
                    </div>
                  )}
                </div>

                {section.button.enable && (
                  <a class="bg-[#232323] h-[60px] inline-flex items-center gap-[8px] px-8 rounded-[80px] hover:bg-[#232323]/90 transition" href={section.button.link}>
                    <span class="text-[#ece5d8] text-[16px] font-medium tracking-[-0.31px]">
                      {section.button.label}
                    </span>
                    <svg class="w-[16px] h-[16px] text-[#ece5d8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path>
                    </svg>
                  </a>
                )}
              </div>

              <!-- Graphic Block -->
              <div class="w-full lg:w-[560px] shrink-0">
                  {isLeft ? (
                     <!-- Graphic B: Dashboard Interface Layout -->
                     <div class="bg-[rgba(35,35,35,0.05)] border border-[rgba(35,35,35,0.1)] w-full h-[490px] rounded-[24px] shadow-[0px_20px_25px_-5px_rgba(0,0,0,0.1)] flex items-center justify-center relative overflow-hidden">
                       <div class="w-[478px] h-[368px] relative scale-75 md:scale-100">
                          <div class="absolute bg-[#f2efeb] border border-[rgba(35,35,35,0.05)] h-[163px] w-[227px] left-0 top-0 rounded-[16px] shadow-sm flex items-end pl-[24px] overflow-hidden">
                             <div class="flex gap-[12px] items-end h-[113px] w-full">
                               <div class="bg-[#e8e5e1] h-[45px] w-[31px] rounded-t-[6px]"></div>
                               <div class="bg-[#c9c6c3] h-[79px] w-[31px] rounded-t-[6px]"></div>
                               <div class="bg-[#dddbd7] h-[56px] w-[31px] rounded-t-[6px]"></div>
                               <div class="bg-[#e8e5e1] h-[102px] w-[31px] rounded-t-[6px]"></div>
                             </div>
                          </div>
                          <div class="absolute bg-[#f2efeb] border border-[rgba(35,35,35,0.05)] h-[163px] w-[227px] right-0 top-0 rounded-[16px] shadow-sm flex flex-col justify-center gap-[20px] p-[24px]">
                             <div class="flex items-center gap-[12px] w-full"><div class="bg-[#dddbd7] h-[12px] w-[32px] rounded-[6px]"></div><div class="bg-[#e8e5e1] h-[12px] flex-1 rounded-[6px]"></div></div>
                             <div class="flex items-center gap-[12px] w-full"><div class="bg-[rgba(35,35,35,0.2)] h-[12px] w-[32px] rounded-[6px]"></div><div class="bg-[rgba(35,35,35,0.1)] h-[12px] w-[133px] rounded-[6px]"></div></div>
                             <div class="flex items-center gap-[12px] w-full"><div class="bg-[#dddbd7] h-[12px] w-[29px] rounded-[6px]"></div><div class="bg-[rgba(35,35,35,0.1)] h-[12px] w-[136px] rounded-[6px]"></div></div>
                             <div class="flex items-center gap-[12px] w-full"><div class="bg-[rgba(35,35,35,0.1)] h-[12px] w-[32px] rounded-[6px]"></div><div class="bg-[rgba(35,35,35,0.1)] h-[12px] w-[88px] rounded-[6px]"></div></div>
                          </div>
                          <div class="absolute bg-[#f2efeb] border border-[rgba(35,35,35,0.05)] h-[167px] w-[227px] left-0 bottom-0 rounded-[16px] shadow-sm flex items-center justify-center">
                             <div class="h-[96px] w-[96px] rounded-full border-[15px] border-[#c9c6c3]"></div>
                          </div>
                          <div class="absolute bg-[#f2efeb] border border-[rgba(35,35,35,0.05)] h-[167px] w-[227px] right-0 bottom-0 rounded-[16px] shadow-sm flex items-center justify-center overflow-hidden">
                            <svg class="h-[101px] w-[177px] text-[#c9c6c3] opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21A10 10 0 0012 3a10 10 0 000 18z"></path>
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 7v10M8 11l4-4 4 4"></path>
                            </svg>
                          </div>
                       </div>
                     </div>
                  ) : (
                     <!-- Graphic A: Editor Details Layout -->
                     <div class="bg-[#e7e4dc] border border-[rgba(35,35,35,0.1)] w-full h-[468px] rounded-[24px] shadow-[0px_25px_50px_-12px_rgba(0,0,0,0.25)] flex overflow-hidden items-center justify-center relative">
                       <div class="absolute w-[478px] h-[370px] border-[1.5px] border-dashed border-[rgba(35,35,35,0.2)] bg-[rgba(35,35,35,0.02)] rounded-[16px] p-[33px] flex flex-col items-center justify-center gap-[40px] scale-75 md:scale-100">
                          <div class="w-full flex flex-col items-center gap-[12px]">
                            <div class="bg-[rgba(35,35,35,0.1)] h-[16px] w-[137px] rounded-full"></div>
                            <div class="bg-[rgba(35,35,35,0.05)] h-[32px] w-[308px] rounded-[10px]"></div>
                            <div class="bg-[rgba(35,35,35,0.05)] h-[16px] w-[205px] rounded-full"></div>
                          </div>
                          <div class="flex gap-[25px] w-full justify-center h-[177px]">
                            <div class="bg-[#f2efeb] border border-[rgba(35,35,35,0.1)] shadow-sm rounded-[14px] w-[178px] p-[20px] flex flex-col items-start gap-[12px]">
                              <div class="bg-[rgba(35,35,35,0.2)] h-[32px] w-[32px] rounded-[8px] mb-2"></div>
                              <div class="bg-[rgba(35,35,35,0.1)] h-[8px] w-[137px] rounded-full"></div>
                              <div class="bg-[rgba(35,35,35,0.1)] h-[8px] w-[109px] rounded-full mt-1"></div>
                              <div class="bg-[rgba(35,35,35,0.05)] h-[32px] w-[137px] rounded-[8px] mt-2"></div>
                            </div>
                            <div class="bg-[rgba(255,255,255,0.5)] border-[1.5px] border-dashed border-[rgba(35,35,35,0.1)] rounded-[14px] w-[208px] flex items-center justify-center">
                              <span class="text-[36px] font-light text-[rgba(35,35,35,0.2)] leading-none mb-2">+</span>
                            </div>
                          </div>
                       </div>
                     </div>
                  )}
              </div>

            </div>
          );
        })
      }
    </div>
  </div>
</section>
