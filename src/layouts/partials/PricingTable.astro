---
import { markdownify } from "@/lib/utils/textConverter";

const { pricing } = Astro.props;
---

<section class="section">
  <div class="container relative z-10 w-full">
    <div class="flex flex-col gap-[56px] items-center relative size-full">
      <!-- Pricing Header -->
      <div class="flex flex-col gap-[32px] items-center relative w-full">
        <div class="flex flex-col gap-[24px] items-center text-center">
          <h2
            set:html={markdownify(pricing.title)}
            class="font-bold leading-[1.4] text-[#232323] text-[40px] md:text-[61px] tracking-[0.35px]"
          />
          <p
            set:html={markdownify(pricing.description)}
            class="font-normal leading-[28px] text-[18px] md:text-[20px] text-[rgba(35,35,35,0.8)] tracking-[-0.45px]"
          />
        </div>
        
        <!-- Pricing Toggle -->
        <div class="bg-white border border-[#c6baaf] flex gap-[20px] items-center pl-[8px] pr-[20px] py-[8px] rounded-[100px]">
          <div class="bg-[#121212] flex items-center pb-[12px] pt-[8px] px-[24px] rounded-[100px] cursor-pointer">
            <p class="font-medium leading-[1.5] text-[16px] text-white">
              Monthly
            </p>
          </div>
          <p class="font-medium leading-[1.5] text-[16px] text-[#606977] cursor-pointer cursor-pointer">
            Yearly <span class="text-[#232323]">(40% Off)</span>
          </p>
        </div>
      </div>

      <!-- Pricing Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-[24px] w-full">
        {
          pricing.plans.map((plan: any) => {
            const isPopular = plan.popular;
            
            return (
              <div class={`relative rounded-[20px] shrink-0 w-full flex flex-col justify-between p-[31px] md:h-[564px] border ${isPopular ? "bg-[#232323] border-[rgba(35,35,35,0.2)] shadow-[0px_15px_50px_0px_rgba(0,0,0,0.15)]" : "bg-[#f5f4f1] border-[rgba(35,35,35,0.2)] shadow-[0px_10px_25px_-3px_rgba(0,0,0,0.06),0px_4px_26px_-4px_rgba(0,0,0,0.06)]"}`}>
                
                {isPopular && (
                  <div class="absolute -translate-x-1/2 left-1/2 top-[-17px] bg-[#232323] border border-[#f5f4f1] flex items-center justify-center px-[16px] py-[8px] rounded-full shadow-[0px_4px_6px_0px_rgba(0,0,0,0.1),0px_2px_4px_0px_rgba(0,0,0,0.1)]">
                    <p class="font-bold leading-[16px] text-[#f1eee6] text-[12px] tracking-[2.4px] uppercase whitespace-nowrap">
                      Most Popular
                    </p>
                  </div>
                )}

                <div class="flex flex-col relative">
                  <div class="flex flex-col gap-[24px] items-start w-full mb-[24px]">
                    <div class={`flex flex-col gap-[16px] items-start w-full ${isPopular ? "text-[#f1eee6]" : "text-[#232323]"}`}>
                      <div class="flex flex-col gap-[8px] items-start leading-[1.4] w-full">
                        <p class="font-semibold text-[25px] whitespace-nowrap">
                          {plan.name}
                        </p>
                        <p class="font-normal text-[18px]">
                          {plan.subtitle}
                        </p>
                      </div>
                      <p class="leading-[0] w-full mt-2">
                        <span class="font-semibold leading-[1.3] text-[48px]">${plan.price}</span>
                        <span class="font-medium leading-[1.5] text-[16px]">/month</span>
                      </p>
                    </div>
                    <div class={`w-full h-px ${isPopular ? "bg-[#f1eee6]/20" : "bg-[rgba(35,35,35,0.2)]"}`}></div>
                  </div>

                  <div class="flex flex-col gap-[16px] items-start">
                    <p class={`font-semibold leading-[1.5] text-[16px] whitespace-nowrap ${isPopular ? "text-[#f1eee6]" : "text-[#232323]"}`}>What's Included</p>
                    <div class="flex flex-col gap-[8px] items-start">
                      {plan.features.map((feature: string) => (
                        <div class="flex gap-[8px] items-center w-full">
                          <div class="relative shrink-0 size-[24px] flex items-center justify-center">
                            <svg class={`w-5 h-5 ${isPopular ? "text-[#f1eee6]" : "text-[#232323]"}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                          </div>
                          <p class={`font-normal leading-[1.5] text-[16px] whitespace-nowrap ${isPopular ? "text-[#f1eee6]" : "text-[#3d434c]"}`}>
                            {feature}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>

                <a href="#" class={`mt-8 md:mt-0 border flex gap-[8px] items-center justify-center px-[38px] py-[12px] rounded-full w-full relative transition-all duration-300 ${isPopular ? "border-[#f1eee6] text-[#f1eee6] hover:bg-[#f1eee6] hover:text-[#232323]" : "border-[#121212] text-[#121212] hover:bg-[#232323] hover:text-white"}`}>
                  <p class="font-medium leading-[1.5] text-[16px] text-center whitespace-nowrap">
                    Get Started
                  </p>
                  <div class="flex items-center justify-center relative shrink-0 size-[24px]">
                    <svg class="w-5 h-5 transform rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 11l7-7 7 7M12 4v16" />
                    </svg>
                  </div>
                </a>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
