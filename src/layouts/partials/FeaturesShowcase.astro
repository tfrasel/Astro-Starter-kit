---
---

<section class="section w-full flex justify-center overflow-hidden">
  <div class="w-full max-w-[1320px] px-6 xl:px-0 flex flex-col gap-[140px]">
    <!-- First Section: Built for Performance -->
    <div class="flex flex-col lg:flex-row items-center gap-[68px]">
      <div class="w-full lg:w-[692px] flex flex-col gap-[48px]">
        <div class="flex flex-col gap-[16px]">
          <div class="flex flex-col gap-4">
            <span class="text-[14px] font-bold text-[#232323]/50 tracking-[2.6496px] uppercase leading-[20px]">
              Built for Performance
            </span>
            <h2 class="text-[48px] md:text-[61px] font-bold text-[#232323] tracking-[0.3516px] leading-[1.2]">
              Fast, modern, and easy to work with
            </h2>
          </div>
          <p class="text-[20px] text-[#232323]/80 leading-[28px] tracking-[-0.4395px]">
            This component starter takes full advantage of our zero-JS-by-default approach. You get fast pages, simple routing, and a component system that stays easy to use as your site grows.
          </p>
        </div>
        
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <div class="w-6 h-6 flex items-center justify-center text-[#232323]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>
            </div>
            <p class="text-[16px] text-[#232323]/80 tracking-[-0.4395px] leading-[28px]">Zero JS, by default: No JavaScript runtime overhead to slow you down.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-6 h-6 flex items-center justify-center text-[#232323]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>
            </div>
            <p class="text-[16px] text-[#232323]/80 tracking-[-0.4395px] leading-[28px]">Customizable: Tailwind, MDX, and 100+ other integrations to choose from.</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-6 h-6 flex items-center justify-center text-[#232323]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"></path></svg>
            </div>
            <p class="text-[16px] text-[#232323]/80 tracking-[-0.4395px] leading-[28px]">UI-agnostic: Supports React, Vue, Svelte, and more.</p>
          </div>
        </div>

        <a href="/contact" class="bg-[#232323] text-[#ece5d8] px-9 py-4 rounded-[80px] font-medium text-[16px] tracking-[-0.3125px] w-fit hover:bg-opacity-90 transition inline-flex items-center gap-2">
          Get Started Now
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12l5-4-5-4"></path>
          </svg>
        </a>
      </div>

      <div class="w-full lg:w-[560px] h-[468px] bg-[#e7e4dc] border border-[#232323]/10 rounded-[24px] shadow-[0px_15px_50px_-12px_rgba(0,0,0,0.15)] relative overflow-hidden flex items-center justify-center p-10">
        <!-- Mock UI Visual -->
        <div class="w-full flex flex-col gap-10">
          <div class="flex flex-col gap-3 items-center">
            <div class="h-4 bg-[#232323]/10 rounded-full w-[137px]"></div>
            <div class="h-8 bg-[#232323]/5 rounded-[10px] w-full"></div>
            <div class="h-4 bg-[#232323]/5 rounded-full w-[205px]"></div>
          </div>
          <div class="flex gap-4">
            <div class="flex-1 bg-[#f2efeb] rounded-[14px] p-5 shadow-sm border border-[#232323]/10 h-[177px] flex flex-col gap-4">
              <div class="w-8 h-8 bg-[#232323]/20 rounded-lg"></div>
              <div class="h-2 bg-[#232323]/10 rounded-full w-4/5"></div>
              <div class="h-2 bg-[#232323]/10 rounded-full w-3/5"></div>
              <div class="h-8 bg-[#232323]/5 rounded-lg w-full mt-auto"></div>
            </div>
            <div class="flex-1 bg-white/50 border-2 border-dashed border-[#232323]/10 rounded-[14px] flex items-center justify-center text-[36px] text-[#232323]/20 font-light">
              +
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Second Section: CloudCannon Ready -->
    <div class="flex flex-col lg:flex-row-reverse items-center gap-[112px]">
      <div class="w-full lg:w-[632px] flex flex-col gap-[48px]">
        <div class="flex flex-col gap-[16px]">
          <span class="text-[14px] font-bold text-[#232323]/50 tracking-[2.6496px] uppercase leading-[20px]">
            CloudCannon Ready
          </span>
          <div class="flex flex-col gap-10">
            <h2 class="text-[48px] md:text-[61px] font-bold text-[#232323] tracking-[0.3516px] leading-[1.4]">
              Everything you need to <span class="underline decoration-solid">ship your next app</span>
            </h2>
            <p class="text-[20px] text-[#232323]/80 leading-[28px] tracking-[-0.4395px]">
              This component starter takes full advantage of our zero-JS-by-default approach. You get fast pages, simple routing, and a component system that stays easy to use as your site grows.
            </p>
          </div>
        </div>

        <a href="/contact" class="bg-[#232323] text-[#ece5d8] px-9 py-4 rounded-[80px] font-medium text-[16px] tracking-[-0.3125px] w-fit hover:bg-opacity-90 transition inline-flex items-center gap-2">
          Get Started Now
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12l5-4-5-4"></path>
          </svg>
        </a>
      </div>

      <div class="w-full lg:w-[560px] h-[490px] bg-[#232323]/5 border border-[#232323]/10 rounded-[24px] shadow-[0px_20px_25px_-5px_rgba(0,0,0,0.1)] relative overflow-hidden flex items-center justify-center p-10">
          <div class="grid grid-cols-2 gap-4 w-full h-full p-4">
             <div class="bg-[#f2efeb] rounded-2xl shadow-sm border border-[#232323]/5 p-6 flex flex-col justify-end">
                <div class="flex items-end gap-3 h-full">
                    <div class="w-[31px] bg-[#e8e5e1] rounded-t-md h-1/3"></div>
                    <div class="w-[31px] bg-[#c9c6c3] rounded-t-md h-2/3"></div>
                    <div class="w-[31px] bg-[#dddbd7] rounded-t-md h-1/2"></div>
                    <div class="w-[31px] bg-[#e8e5e1] rounded-t-md h-4/5"></div>
                </div>
             </div>
             <div class="bg-[#f2efeb] rounded-2xl shadow-sm border border-[#232323]/5 p-6 flex flex-col gap-5 justify-center">
                <div class="flex gap-3 items-center">
                   <div class="w-[32px] h-[12px] bg-[#dddbd7] rounded-full"></div>
                   <div class="flex-1 h-[12px] bg-[#e8e5e1] rounded-full"></div>
                </div>
                <div class="flex gap-3 items-center">
                   <div class="w-[32px] h-[12px] bg-[#232323]/20 rounded-full"></div>
                   <div class="w-[133px] h-[12px] bg-[#232323]/10 rounded-full"></div>
                </div>
                <div class="flex gap-3 items-center">
                   <div class="w-[29px] h-[12px] bg-[#dddbd7] rounded-full"></div>
                   <div class="w-[136px] h-[12px] bg-[#232323]/10 rounded-full"></div>
                </div>
                <div class="flex gap-3 items-center">
                   <div class="w-[32px] h-[12px] bg-[#232323]/10 rounded-full"></div>
                   <div class="w-[88px] h-[12px] bg-[#232323]/10 rounded-full"></div>
                </div>
             </div>
             <div class="bg-[#f2efeb] rounded-2xl shadow-sm border border-[#232323]/5 p-6 flex items-center justify-center">
                <div class="w-24 h-24 border-[15px] border-[#c9c6c3] rounded-full"></div>
             </div>
             <div class="bg-[#f2efeb] rounded-2xl shadow-sm border border-[#232323]/5 p-6 relative flex items-center justify-center">
                <div class="w-full h-full bg-[#c9c6c3]/20 rounded-lg flex items-center justify-center">
                   <svg class="w-12 h-12 text-[#232323]/20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L1 21h22L12 2z"/></svg>
                </div>
                <div class="absolute top-4 right-4 w-3 h-3 bg-[#c9c6c3] rounded-full shadow-md"></div>
             </div>
          </div>
      </div>
    </div>
  </div>
</section>
