---
const { data, showViewAll = false } = Astro.props;
---

<!-- Open Positions Section -->
<section id="open-positions" class="section-bg bg-[#ebe9e2]">
  <div class="mx-auto w-full max-w-[1320px] px-6 xl:px-0 flex flex-col items-center">
    <div class="w-full">
      
      <!-- Header Row -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-[40px] mb-[60px]">
        <div class="flex flex-col gap-[30px] max-w-[533px]">
          <h2 class="font-bold leading-[1.2] text-[#232323] text-[48px] md:text-[61px] font-primary m-0 text-center md:text-left whitespace-nowrap">
            {data.title}
          </h2>
          <p class="font-normal leading-[1.6] text-[16px] md:text-[18px] text-[rgba(35,35,35,0.7)] m-0 font-primary max-w-[533px]">
            {data.description}
          </p>
        </div>

        <!-- Filter Options -->
        <div id="job-filters" class="flex flex-wrap gap-[8px] shrink-0">
          {data.categories.map((category: string, index: number) => (
            <button 
              class={`job-filter-btn px-[21px] py-[7px] rounded-[28px] font-medium text-[16px] leading-[1.6] transition-all duration-300 font-primary border whitespace-nowrap ${
                index === 0 
                  ? 'active-filter bg-[#232323] text-[#f5f4f1] border-[#232323]' 
                  : 'bg-[#f5f4f1] text-[#232323] border-[rgba(35,35,35,0.2)] hover:bg-[#232323] hover:text-white hover:border-[#232323]'
              }`}
              data-category={category.toLowerCase()}
            >
              {category}
            </button>
          ))}
        </div>
      </div>

      <!-- Jobs List -->
      <div id="jobs-list" class="flex flex-col gap-[30px]">
        {data.jobs.map((job: any, index: number) => (
          <div class="job-item bg-[#f5f4f1] rounded-[16px] px-[40px] py-[56px] transition-all duration-300" data-category={job.category.toLowerCase()}>
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-[32px]">
              
              <!-- Left: Tags + Title -->
              <div class="flex flex-col gap-[16px]">
                <!-- Tags row -->
                <div class="flex flex-wrap items-center gap-[16px]">
                  <span class="bg-[rgba(35,35,35,0.05)] px-[12px] py-[6px] rounded-[8px] font-medium text-[16px] text-[#232323] leading-[1.6] whitespace-nowrap">
                    {job.category}
                  </span>
                  <div class="flex items-center gap-[16px]">
                    <div class="flex items-center gap-[8px]">
                      <svg class="w-4 h-4 text-[rgba(35,35,35,0.5)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="font-medium text-[16px] text-[#232323] leading-[1.6] whitespace-nowrap">{job.type}</span>
                    </div>
                    <div class="flex items-center gap-[8px]">
                      <svg class="w-4 h-4 text-[rgba(35,35,35,0.5)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      <span class="font-medium text-[16px] text-[#232323] leading-[1.6] whitespace-nowrap">{job.location}</span>
                    </div>
                  </div>
                </div>
                <!-- Job title -->
                <h3 class="font-semibold text-[31px] text-[#232323] leading-[1.4] font-primary m-0 whitespace-nowrap">
                  {job.title}
                </h3>
              </div>

              <!-- Right: Salary + Apply Now -->
              <div class="flex items-center gap-[80px] md:gap-[120px] shrink-0">
                <!-- Salary -->
                <div class="flex flex-col gap-[8px]">
                  <span class="font-normal text-[18px] text-[#232323] leading-[1.6] capitalize">Base Salary Range</span>
                  <span class="font-semibold text-[31px] text-[#232323] leading-[1.4] whitespace-nowrap">{job.salary_range}</span>
                </div>

                <!-- Apply Now button -->
                <a 
                  href={job.link || "#"} 
                  class={`inline-flex items-center justify-center gap-[8px] px-[36px] py-[18px] rounded-full font-medium text-[16px] leading-[24px] tracking-[-0.31px] whitespace-nowrap transition-all duration-300 ${
                    index === 0 
                      ? 'bg-[#232323] text-[#ece5d8] border border-[#232323] hover:opacity-90' 
                      : 'border border-[rgba(35,35,35,0.2)] text-[#232323] bg-transparent hover:bg-[#232323] hover:text-white hover:border-[#232323]'
                  }`}
                >
                  Apply Now
                  <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3.333 8h9.334M9.333 4.667l3.334 3.333-3.334 3.334" />
                  </svg>
                </a>
              </div>

            </div>
          </div>
        ))}
      </div>

      <!-- View All Positions Link -->
      {showViewAll && (
        <div class="mt-[60px] flex justify-center">
          <a 
            href="/careers" 
            class="inline-flex items-center gap-[12px] font-semibold text-[18px] text-[#232323] group transition-all duration-300 border-b-2 border-transparent hover:border-[#232323] pb-1"
          >
            Explore All Open Positions
            <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.167 10h11.666M10.833 5l5 5-5 5" />
            </svg>
          </a>
        </div>
      )}

    </div>
  </div>
</section>

<script>
  const filterButtons = document.querySelectorAll('.job-filter-btn');
  const jobItems = document.querySelectorAll('.job-item');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      // Update active state
      filterButtons.forEach(b => {
        b.classList.remove('active-filter', 'bg-[#232323]', 'text-[#f5f4f1]', 'border-[#232323]');
        b.classList.add('bg-[#f5f4f1]', 'text-[#232323]', 'border-[rgba(35,35,35,0.2)]');
      });
      btn.classList.add('active-filter', 'bg-[#232323]', 'text-[#f5f4f1]', 'border-[#232323]');
      btn.classList.remove('bg-[#f5f4f1]', 'text-[#232323]', 'border-[rgba(35,35,35,0.2)]');

      // Filter jobs
      jobItems.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        if (category === 'all' || itemCategory === category) {
          (item as HTMLElement).style.display = 'block';
          setTimeout(() => {
            (item as HTMLElement).style.opacity = '1';
            (item as HTMLElement).style.transform = 'translateY(0)';
          }, 10);
        } else {
          (item as HTMLElement).style.opacity = '0';
          (item as HTMLElement).style.transform = 'translateY(10px)';
          setTimeout(() => {
            (item as HTMLElement).style.display = 'none';
          }, 300);
        }
      });
    });
  });
</script>
