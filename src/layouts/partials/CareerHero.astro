---
const { data } = Astro.props;
---

<section class="relative w-full z-10 top-0 overflow-hidden">
  <div
    class="mx-auto w-full pt-[228px] pb-0 relative top-0 flex flex-col items-center"
  >
    <div
      class="w-full max-w-[1320px] text-center px-6 xl:px-0 relative z-20 flex flex-col items-center"
    >
      <!-- Badge pill -->
      <div
        class="inline-flex items-center gap-2 rounded-full border border-[rgba(35,35,35,0.2)] bg-[#f7f5f0] px-[16px] py-[8px] shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1),0px_1px_2px_0px_rgba(0,0,0,0.1)] mb-8"
      >
        <span
          class="w-[8px] h-[8px] rounded-full bg-[#232323] border-[3px] border-[#e7e3de]"
        ></span>
        <span
          class="text-[14px] font-semibold text-[#232323] tracking-[-0.15px] leading-[20px] capitalize"
          >{data.subtitle || "Career"}</span
        >
      </div>

      <!-- Title -->
      <h1
        class="font-bold leading-[1.2] text-[#232323] text-[48px] md:text-[80px] tracking-[-2.4px] m-0 max-w-[1005px] font-primary"
      >
        {data.title}
      </h1>

      <!-- Description -->
      <p
        class="font-medium leading-[32.5px] text-[rgba(35,35,35,0.7)] text-[18px] md:text-[20px] max-w-[1005px] mt-[32px] mb-[48px] m-0 font-primary"
      >
        {data.description}
      </p>

      <!-- CTA Button -->
      {
        data.button_label && (
          <a
            href="#open-positions"
            class="inline-flex items-center justify-center bg-[#232323] text-white px-[36px] py-[18px] rounded-full font-semibold text-[16px] leading-[24px] transition hover:bg-black/90 font-primary"
          >
            {data.button_label}
          </a>
        )
      }
    </div>
  </div>

  <!-- Hero Gallery Container (Exact Figma 2-Row Grid) -->
  <div
    class="mx-auto w-full max-w-[1320px] px-6 xl:px-0 relative mt-[64px] z-20 pb-0"
  >
    <div class="flex flex-col gap-6 w-full">
      <!-- Row 1: Big-Small-Small -->
      <div class="grid grid-cols-4 gap-6 h-[319px]">
        <div
          class="col-span-2 rounded-[24px] overflow-hidden"
        >
          <img
            src="/images/image-placeholder.png"
            alt="Gallery 1"
            class="w-full h-full object-cover"
          />
        </div>
        <div
          class="col-span-1 rounded-[24px] overflow-hidden"
        >
          <img
            src="/images/image-placeholder.png"
            alt="Gallery 2"
            class="w-full h-full object-cover"
          />
        </div>
        <div
          class="col-span-1 rounded-[24px] overflow-hidden"
        >
          <img
            src="/images/image-placeholder.png"
            alt="Gallery 3"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
      <!-- Row 2: Small-Small-Big -->
      <div class="grid grid-cols-4 gap-6 h-[319px]">
        <div
          class="col-span-1 rounded-[24px] overflow-hidden"
        >
          <img
            src="/images/image-placeholder.png"
            alt="Gallery 4"
            class="w-full h-full object-cover"
          />
        </div>
        <div
          class="col-span-1 rounded-[24px] overflow-hidden"
        >
          <img
            src="/images/image-placeholder.png"
            alt="Gallery 5"
            class="w-full h-full object-cover"
          />
        </div>
        <div
          class="col-span-2 rounded-[24px] overflow-hidden"
        >
          <img
            src="/images/image-placeholder.png"
            alt="Gallery 6"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
