---
import { markdownify } from "@/lib/utils/textConverter";

const { banner } = Astro.props;
---

<section class="section pb-[140px] !overflow-visible mt-0">
  <div class="container relative">
    <div class="flex flex-col items-center justify-center text-center">
      <!-- Version Pill -->
      <div
        class="mb-10 inline-flex items-center gap-2 rounded-[25811100px] border border-[rgba(35,35,35,0.2)] bg-[#f7f5f0] shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1),0px_1px_2px_0px_rgba(0,0,0,0.1)] px-[13px] h-[36px]"
      >
        <span
          class="flex h-[8px] w-[8px] rounded-[100px] bg-[#232323] border-[3px] border-[#e7e3de]"
        ></span>
        <span
          class="text-[14px] font-semibold text-[#232323] tracking-[-0.15px] leading-[20px]"
          >Version 1.0 is now live</span
        >
        <svg
          class="w-[14px] h-[14px] text-[#232323]"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
        >
      </div>

      <!-- Title & Subtitle -->
      <h1
        set:html={banner.title}
        class="mb-8 text-[48px] md:text-[88px] font-bold leading-[1.05] md:leading-[92.4px] tracking-[-2.2px] text-[#232323] w-full max-w-[1021px] mx-auto"
      />

      <p
        set:html={markdownify(banner.content)}
        class="mb-12 text-[24px] font-normal text-[rgba(35,35,35,0.7)] tracking-[0.07px] leading-[39px] max-w-[644px] w-full"
      />

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row items-center gap-[16px]">
        {
          banner.button.enable && (
            <a
              class="flex items-center justify-center bg-[#232323] text-[#ece5d8] rounded-[80px] h-[60px] w-[235px] text-[16px] font-medium tracking-[-0.31px] gap-2 hover:bg-primary/90 transition shadow-sm"
              href={banner.button.link}
            >
              {banner.button.label}
              <svg
                class="w-4 h-4 ml-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"
                />
              </svg>
            </a>
          )
        }
        {
          banner.secondary_button.enable && (
            <a
              class="flex items-center justify-center bg-transparent border border-[rgba(35,35,35,0.2)] text-[#232323] rounded-[80px] h-[60px] w-[242px] text-[16px] font-medium tracking-[-0.31px] gap-2 hover:bg-[#232323] hover:text-[#ece5d8] hover:border-[#232323] transition-all duration-300"
              href={banner.secondary_button.link}
            >
              <svg
                viewBox="0 0 24 24"
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                />
              </svg>
              {banner.secondary_button.label}
            </a>
          )
        }
      </div>

      <!-- CSS Replica of Code Window -->
      <div
        class="mt-[64px] mb-0 relative flex justify-center w-[1106px] max-w-full"
      >
        <div
          class="relative w-full rounded-[20px] border-[0.94px] border-[rgba(255,255,255,0.1)] bg-[#232323] shadow-[0px_30px_61px_-14px_rgba(50,27,21,0.4)] overflow-visible skew-x-[0.59deg] transform transition-transform duration-700 tilt-card h-[542px]"
        >
          <!-- Window Header (Absolute positioning matched to Figma) -->
          <div
            class="absolute top-0 left-0 w-full h-[93.4px] bg-[rgba(255,255,255,0.05)] border-b-[0.94px] border-[rgba(255,255,255,0.1)]"
          >
            <div class="absolute left-[27px] top-[40px] flex gap-[9.7px]">
              <span class="h-[15px] w-[16px] rounded-full bg-[#ff5f56]"></span>
              <span class="h-[15px] w-[16px] rounded-full bg-[#ffbd2e]"></span>
              <span class="h-[15px] w-[16px] rounded-full bg-[#27c93f]"></span>
            </div>
            <div
              class="absolute left-1/2 -translate-x-1/2 top-[30px] flex h-[31.6px] w-[130px] items-center justify-center rounded-[9.8px] bg-[rgba(255,255,255,0.05)] text-[14.6px] font-mono text-[rgba(236,229,216,0.4)]"
            >
              <span class="mr-2">&lt;/&gt;</span> index.tsx
            </div>
          </div>
          <!-- Window Body -->
          <div
            class="absolute top-[110px] left-[43px] text-left font-mono text-[19.5px] leading-[31.8px] text-[rgba(236,229,216,0.8)]"
          >
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">1</span><span
                class="text-[#ff7b72]">import</span
              ><span>&nbsp;&#123;&nbsp;</span><span class="text-[#d2a8ff]"
                >StarterTemplate</span
              ><span>&nbsp;&#125;&nbsp;</span><span class="text-[#ff7b72]"
                >from</span
              ><span>&nbsp;</span><span class="text-[#a5d6ff]">'@ivory/ui'</span
              ><span>;</span>
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">2</span><span
                class="text-[#ff7b72]">import</span
              ><span>&nbsp;</span><span class="text-[#a5d6ff]"
                >'./theme.css'</span
              ><span>;</span>
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">3</span>
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">4</span><span
                class="text-[#ff7b72]">export default function</span
              ><span>&nbsp;</span><span class="text-[#d2a8ff]">App</span><span
                >() &#123;</span
              >
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">5</span><span
                >&nbsp;&nbsp;</span
              ><span class="text-[#ff7b72]">return</span><span>&nbsp;(</span>
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">6</span><span
                >&nbsp;&nbsp;&nbsp;&nbsp;&lt;</span
              ><span class="text-[#7ee787]">StarterTemplate</span>
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">7</span><span
                >&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span
              ><span class="text-[#a5d6ff]">theme</span><span
                class="text-[#ece5d8]">=</span
              ><span class="text-[#a5d6ff]">"ivory-cocoa"</span>
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">8</span><span
                >&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span
              ><span class="text-[#a5d6ff]">performance</span><span
                class="text-[#ece5d8]">=</span
              ><span>&#123;</span><span class="text-[#79c0ff]">100</span><span
                >&#125;</span
              >
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">9</span><span
                >&nbsp;&nbsp;&nbsp;&nbsp;/&gt;</span
              >
            </div>
            <div class="flex mb-[4.5px]">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">10</span><span
                >&nbsp;&nbsp;);</span
              >
            </div>
            <div class="flex">
              <span class="w-12 text-[rgba(236,229,216,0.3)]">11</span><span
                >&#125;</span
              >
            </div>
          </div>
        </div>

        <!-- Play icon overlay center container -->
        <div
          class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none z-10 skew-x-[0.59deg]"
        >
          <div
            class="flex h-[88px] w-[88px] items-center justify-center rounded-full bg-[#f1eee6] shadow-[0px_0px_40px_0px_rgba(255,255,255,0.6)] text-[#232323]"
          >
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              class="ml-1"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon points="5 3 19 12 5 21 5 3"></polygon></svg
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tilt-card {
    transform: rotateX(5deg) scale(0.98);
  }
  .tilt-card:hover {
    transform: rotateX(0deg) scale(1);
  }
</style>
