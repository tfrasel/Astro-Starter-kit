---
import { markdownify } from "@/lib/utils/textConverter";

const { faq } = Astro.props;
---

<section class="section">
  <div class="container px-0 md:px-4">
    <!-- FAQ Section (Node 128:11156) -->
    <div class="flex flex-col items-center gap-[64px] px-6 xl:px-0 relative w-full xl:max-w-[1320px] mx-auto">
      <div class="flex flex-col items-center text-center gap-[16px]">
        <h2
          set:html={markdownify(faq.title)}
          class="font-bold leading-[1.4] text-[#232323] text-[40px] md:text-[61px] tracking-[0.37px] font-primary m-0 p-0"
        />
        <p
          set:html={markdownify(faq.description)}
          class="font-normal leading-[28px] text-[18px] md:text-[18px] text-[rgba(35,35,35,0.6)] tracking-[-0.44px] m-0 p-0 font-primary"
        />
      </div>

      <div class="flex flex-col gap-[16px] w-full max-w-[870px]">
        {
          faq.questions.map((faqItem: any) => (
            <details class="group bg-[#f5f4f1] border border-[rgba(35,35,35,0.1)] rounded-[16px] shadow-[0px_1px_3px_0px_rgba(0,0,0,0.1),0px_1px_2px_-1px_rgba(0,0,0,0.1)] overflow-hidden [&_summary::-webkit-details-marker]:hidden transition-all duration-300">
              <summary class="flex cursor-pointer items-center justify-between px-[23px] py-[23px] min-h-[80px] select-none">
                <span class="font-bold leading-[28px] text-[#232323] text-[16px] md:text-[20px] tracking-[-0.45px] font-primary pr-4">
                  {faqItem.question}
                </span>
                <span class="flex items-center justify-center bg-[rgba(35,35,35,0.05)] border border-[rgba(35,35,35,0.1)] rounded-full w-[31.995px] h-[31.995px] shrink-0 transition-transform duration-300 group-open:rotate-45 relative">
                  <svg class="w-[14px] h-[14px] text-[#232323] absolute pointer-events-none" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="0" x2="7" y2="14" />
                    <line x1="0" y1="7" x2="14" y2="7" />
                  </svg>
                </span>
              </summary>
              <div class="px-[23px] pb-[23px] pt-0 text-[16px] md:text-[18px] text-[rgba(35,35,35,0.8)] font-primary leading-[28px] tracking-[-0.44px] opacity-0 group-open:opacity-100 transition-opacity duration-300">
                <p set:html={markdownify(faqItem.answer)} />
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
